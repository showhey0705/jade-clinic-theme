					"color": "#1E1E26"
				},
				{
					"name": "Contrast Accent",
					"slug": "main-accent",
					"color": "#d4d4ec"
				},
				{
					"name": "Base",
					"slug": "base",
					"color": "#fff"
				},
				{
					"name": "Base Accent",
					"slug": "secondary",
					"color": "#545473"
				},
				{
					"name": "Tint",
					"slug": "tertiary",
					"color": "#f8f7fc"
				},
				{
					"name": "Border Base",
