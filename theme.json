			},
			"writingMode": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true,
			"textColumns": true,
			"lineHeight": true,
			"fontFamilies": [
				{
					"fontFamily": "\"fot-tsukuaoldmin-pr6n\", 'Hiragino Mincho ProN', '游明朝', serif",
