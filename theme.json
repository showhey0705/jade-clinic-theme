		"custom": {
			"line-green": "#06C755",
			"line-green-fg": "#FFFFFF",
			"sale": "#E11D48",
			"sale-fg": "#FFFFFF",
			"fontWeight": {
				"thin": 100,
				"extra-light": 200,
				"light": 300,
				"regular": 420,
				"medium": 500,
				"semi-bold": 600,
				"bold": 700,
				"extra-bold": 800,
				"black": 900
