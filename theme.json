{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"link": true,
			"gradients": [
				{
					"name": "Rainbow",
					"slug": "rainbow",
					"gradient": "linear-gradient(135deg in oklch, #e8e8ff 10%, #ffddab 37%, #fcbbbf 69%, #bdebe8 75%, #ffefcd 85%)"
				},
				{
					"name": "Radial",
					"slug": "radial",
					"gradient": "radial-gradient(farthest-side at 73% 21%, transparent, #1a1d29)"
				},
				{
					"name": "Background Subtle",
					"slug": "bg-subtle",
					"gradient": "linear-gradient(0deg, var(--wp--preset--color--tertiary), var(--wp--preset--color--base))"
				},
				{
					"name": "Background Subtle 2",
