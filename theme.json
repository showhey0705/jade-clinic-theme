			"lineHeight": {
				"overlap": 0.88,
				"none": 1,
				"tight": 1.1,
				"snug": 1.2,
				"body": 1.5,
				"relaxed": 1.725,
				"loose": 2
			}
		},
		"layout": {
			"contentSize": "640px",
			"wideSize": "1280px"
		},
