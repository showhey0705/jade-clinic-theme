{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"title": "モダンポップ",
	"slug": "modern-pop-jp",
	"styles": {
		"typography": {
			"fontFamily": "\"M PLUS 1p\", \"メイリオ\", \"Meiryo\", sans-serif",
			"fontSize": "var(--wp--preset--font-size--base)",
			"fontWeight": "400",
			"lineHeight": "1.75",
			"letterSpacing": "0.02em"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "\"M PLUS 1p\", \"メイリオ\", \"Meiryo\", sans-serif",
					"fontWeight": "800",
					"lineHeight": "1.3",
					"letterSpacing": "0.02em"
				}
			},
			"h1": {
				"typography": {
					"fontWeight": "900",
					"letterSpacing": "0",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontWeight": "800",
					"letterSpacing": "0.01em",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontWeight": "700",
					"letterSpacing": "0.02em",
					"lineHeight": "1.4"
				}
			},
			"h4": {
				"typography": {
					"fontWeight": "700",
					"letterSpacing": "0.03em"
				}
			},
			"h5": {
				"typography": {
					"fontWeight": "600",
					"letterSpacing": "0.03em"
				}
			},
			"h6": {
				"typography": {
					"fontWeight": "600",
					"letterSpacing": "0.04em"
				}
			},
			"link": {
				"typography": {
					"fontWeight": "500",
					"textDecoration": "none"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"typography": {
					"lineHeight": "1.75",
					"letterSpacing": "0.02em"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "\"Kiwi Maru\", \"M PLUS Rounded 1c\", sans-serif",
					"fontStyle": "normal",
					"fontWeight": "400",
					"letterSpacing": "0.03em",
					"lineHeight": "1.8"
				}
			},
			"core/button": {
				"typography": {
					"fontFamily": "\"Kiwi Maru\", \"M PLUS Rounded 1c\", sans-serif",
					"fontWeight": "500",
					"letterSpacing": "0.05em"
				}
			},
			"core/list": {
				"typography": {
					"lineHeight": "1.8"
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "0.04em"
				}
			}
		}
	},
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"M PLUS 1p\", \"メイリオ\", \"Meiryo\", sans-serif",
					"name": "M PLUS 1p",
					"slug": "m-plus-1p",
					"fontFace": []
				},
				{
					"fontFamily": "\"Kiwi Maru\", \"M PLUS Rounded 1c\", sans-serif",
					"name": "Kiwi Maru (キウイ丸)",
					"slug": "kiwi-maru",
					"fontFace": []
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					},
					"size": "1rem",
					"slug": "x-small",
					"name": "極小"
				},
				{
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					},
					"size": "1.125rem",
					"slug": "small",
					"name": "小"
				},
				{
					"fluid": {
						"min": "1.0625rem",
						"max": "1.1875rem"
					},
					"size": "1.1875rem",
					"slug": "base",
					"name": "基本"
				},
				{
					"fluid": {
						"min": "1.375rem",
						"max": "1.625rem"
					},
					"size": "1.625rem",
					"slug": "medium",
					"name": "中"
				},
				{
					"fluid": {
						"min": "1.875rem",
						"max": "2.5rem"
					},
					"size": "2.5rem",
					"slug": "large",
					"name": "大"
				},
				{
					"fluid": {
						"min": "2.5rem",
						"max": "3.5rem"
					},
					"size": "3.5rem",
					"slug": "x-large",
					"name": "特大"
				},
				{
					"fluid": {
						"min": "3.5rem",
						"max": "5rem"
					},
					"size": "5rem",
					"slug": "xx-large",
					"name": "極大"
				}
			],
			"customLineHeight": {
				"body": "1.75",
				"heading": "1.3",
				"tight": "1.1",
				"relaxed": "2.0"
			}
		},
		"custom": {
			"typography": {
				"letterSpacing": {
					"body": "0.02em",
					"heading": "0.02em",
					"wide": "0.08em",
					"normal": "0.03em",
					"tight": "0"
				},
				"fontFeatures": {
					"palt": "\"palt\" 1"
				}
			}
		},
		"color": {
			"palette": [
				{
					"slug": "pop-accent",
					"color": "#FF6B6B",
					"name": "ポップアクセント"
				}
			]
		}
	}
}