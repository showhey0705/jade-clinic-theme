{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "LINE 緑",
	"slug": "button-line",
	"blockTypes": ["core/button"],
	"styles": {
		"color": {
			"background": "var:preset|color|line-green",
			"text": "var:preset|color|line-green-fg"
		},
		"border": {
			"radius": "var:preset|spacing|xx-large"
		},
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|medium",
				"right": "var:preset|spacing|medium"
			}
		},
		"shadow": "0 4px 20px rgba(6, 199, 85, 0.25)",
		"css": "& .wp-block-button__link:hover, & .wp-block-button__link:focus { background-color: #05b04c; }"
	}
}
